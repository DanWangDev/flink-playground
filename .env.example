# Flink cluster configuration
FLINK_VERSION=2.2
FLINK_SCALA_VERSION=2.12
COMPOSE_PROJECT_NAME=flink-playground

# Java home (set to your JDK 21 installation)
# On this machine: C:\Program Files\Java\jdk-21.0.11
JAVA_HOME=C:\Program Files\Java\jdk-21.0.11

# Kafka (optional, for module 07 and 13)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Exercise runner options
# STEP_MODE=true      # Enable interactive step-by-step mode
# LOCAL_MODE=true     # Use MiniCluster instead of Docker
